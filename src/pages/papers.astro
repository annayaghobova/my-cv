              return (
                <a
                  href={getPageLink(page)}
                  class={`join-item btn btn-sm ${page === safeCurrentPage ? "btn-active" : ""}`}
                >
                  {page}
                </a>
              );
            })
          }

          <a
            href={getPageLink(Math.min(safeCurrentPage + 1, totalPages))}
            class={`join-item btn btn-sm ${safeCurrentPage === totalPages ? "btn-disabled" : ""}`}
