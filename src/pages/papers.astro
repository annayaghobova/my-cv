---
import Layout from "@/layouts/Layout.astro";
import { publications } from "@/data/cv";
import { highlightAuthor } from "@/lib/utils";

const papersByYear = publications.reduce((groups, paper) => {
  const year = paper.time;

  if (!groups[year]) {
    groups[year] = [];
  }

  groups[year].push(paper);

  return groups;
}, {} as Record<string, typeof publications>);

const sortedYears = Object.keys(papersByYear).sort(
  (a, b) => Number(b) - Number(a)
);
---

<Layout title="Papers">
  <div class="prose max-w-none">
    <h1 class="text-3xl font-bold mb-8">Publications</h1>

    <div class="space-y-10">
      {
        sortedYears.map((year) => (
          <section>
            <h2 class="text-2xl font-bold mb-4 border-b pb-2">{year}</h2>

            <div class="space-y-4">
              {
                papersByYear[year].map((paper) => (
                  <div class="card bg-base-200">
                    <div class="card-body p-5">
                      <h3 class="text-lg font-semibold leading-snug mb-1">
                        <a
                          href={paper.link}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="hover:text-accent"
                        >
                          {paper.title}
                        </a>
                      </h3>

                      <p class="text-sm mb-1">
                        <span set:html={highlightAuthor(paper.authors)} />
                      </p>

                      <p class="text-sm text-base-content/70">
                        <span class="italic">{paper.journal}</span>
                      </p>

                      <div class="card-actions justify-end mt-3">
                        <a
                          href={paper.link}
                          target="_blank"
                          rel="noopener noreferrer"
                          class="btn btn-xs btn-secondary text-secondary-content"
                        >
                          Read Paper
                        </a>
                      </div>
                    </div>
                  </div>
                ))
              }
            </div>
          </section>
        ))
      }
    </div>
  </div>
</Layout>
