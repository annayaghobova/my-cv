---
import { Image } from 'astro:assets'

import SocialIcons from './SocialIcons.astro'


const {fullName, title, institute, profilePicture} = Astro.props
---
<div class='flex-1'>
  <h1 class='text-4xl font-bold mb-4'>
    Welcome! I'm <span class='text-secondary'>{fullName}</span>
  </h1>
  <p class='text-xl text-gray-600 mb-4'>{title}{institute ? ` at ${institute}` : ''}</p>
  <p class='text-lg mb-6'>
    I’m a researcher at the Faculty of Mathematics and Physics, Charles University. My research explores how students make sense of digital systems such as the internet and computers—and what teachers can do to support and refine those ideas. 
    Off-duty, I switch from untangling conceptions to untangling yarn: knitting, crocheting, and occasionally negotiating with cats who believe every project is a team effort. Add good food, good books, and indie rock, and that’s me.
  </p>
  <div class='flex gap-4'>
    <SocialIcons />
  </div>
</div>
<div class='size-72 lg:block hidden'>
  <!-- Add your profile image -->
  <Image
    src={profilePicture}
    alt={fullName}
    class='w-full h-full mask mask-circle object-cover object-center'
  />
</div>
