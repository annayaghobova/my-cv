---
interface Props {
  listTitle: string;
  listItems: {
    title: string;
    type?: string;
    link?: string;
    linkname?: string;
    description: string;
  }[];
}

const { listTitle, listItems } = Astro.props
---

<h2 class="text-2xl font-bold mb-6">{listTitle}</h2>

<div class="grid gap-6 mb-12">
  {
    listItems.map((item) => (
      <div class="p-6 bg-base-200 rounded-xl text-base-content">
        <h3 class="text-xl font-semibold mb-2">{item.title}</h3>

        {item.type && (
          <p class="text-sm text-base-content/70 mb-3">
            {item.type}
          </p>
        )}

        <p>{item.description}</p>

        {item.link && (
          <div class="mt-4">
            <a
              href={item.link}
              target="_blank"
              rel="noopener noreferrer"
              class="btn btn-sm btn-secondary text-secondary-content"
            >
              {item.linkname || "Project website"}
            </a>
          </div>
        )}
      </div>
    ))
  }
</div>
